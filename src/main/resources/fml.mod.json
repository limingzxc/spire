{
  "schemaVersion": 1,
  "id": "spire",
  "version": "${version}",
  "name": "Spire - Slay the Spire in MITE",
  "description": "Roguelike deck-building dungeon crawler mod for MITE. Climb the Spire, collect relics, forge weapon affixes, and conquer three floors.",
  "authors": [
    "limingzxc"
  ],
  "contact": {
    "homepage": "https://github.com/MinecraftIsTooEasy/fish-example-mod",
    "sources": "https://github.com/MinecraftIsTooEasy/fish-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/modid/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "top.limingzxc.spire.SpireMod"
    ],
    "registry": [
      "top.limingzxc.spire.register.SpireRegistryInit"
    ]
  },
  "mixins": [
    "spire.mixins.json"
  ],
  "depends": {
    "fishmodloader": ">=3.4.0",
    "minecraft": "1.6.4-mite",
    "java": ">=17",
    "rusted_iron_core": ">=1.5.0"
  },
  "suggests": {
    "another-mod": "*"
  },
  "accessWidener": "spire.accesswidener"
}